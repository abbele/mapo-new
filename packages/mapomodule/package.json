{
  "name": "mapomodule",
  "version": "0.0.0",
  "description": "Mapo meta-package: registers and re-exports all @mapomodule/* modules",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@mapomodule/core": "workspace:*",
    "@mapomodule/store": "workspace:*",
    "@mapomodule/utils": "workspace:*",
    "@mapomodule/integrations": "workspace:*",
    "@mapomodule/routemeta": "workspace:*",
    "@mapomodule/form": "workspace:*",
    "@mapomodule/uikit": "workspace:*",
    "@mapomodule/i18n": "workspace:*"
  }
}
