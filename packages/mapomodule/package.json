{
  "name": "mapomodule",
  "version": "0.0.0",
  "description": "Mapo meta-package: registers and re-exports all @mapomodule/* modules",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/module.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "prepare": "nuxt-module-build build --stub",
    "dev:prepare": "nuxt-module-build build --stub",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "nuxt": ">=4.0.0"
  },
  "dependencies": {
    "@mapomodule/core": "workspace:*",
    "@mapomodule/form": "workspace:*",
    "@mapomodule/i18n": "workspace:*",
    "@mapomodule/routemeta": "workspace:*",
    "@mapomodule/store": "workspace:*",
    "@mapomodule/uikit": "workspace:*",
    "@mapomodule/utils": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/kit": "4.4.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "4.4.2",
    "nuxt": "^4.4.2",
    "vue": "^3.5.32"
  }
}
