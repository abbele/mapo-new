{
  "name": "@mapomodule/store",
  "version": "0.0.0",
  "description": "Mapo Pinia stores",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    },
    "./runtime/*": {
      "types": "./src/runtime/*",
      "import": "./dist/runtime/*.js",
      "default": "./src/runtime/*"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "nuxt-module-build build --stub --watch",
    "build": "nuxt-module-build build",
    "prepare": "nuxt-module-build build",
    "dev:prepare": "nuxt-module-build build --stub",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "nuxt": ">=4.0.0",
    "pinia": ">=3.0.0"
  },
  "devDependencies": {
    "@nuxt/kit": "4.4.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "4.4.2",
    "@pinia/nuxt": "^0.11.3",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.32"
  }
}
