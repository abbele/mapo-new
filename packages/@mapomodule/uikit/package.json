{
  "name": "@mapomodule/uikit",
  "version": "0.0.0",
  "description": "Mapo UI components: Sidebar, Topbar, Login, SnackBar, ConfirmDialog, List, Detail, Media",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/module.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxt-module-build build --stub --watch",
    "prepare": "nuxt-module-build build --stub",
    "dev:prepare": "nuxt-module-build build --stub",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@mapomodule/form": "workspace:*",
    "@mapomodule/store": "workspace:*",
    "@mapomodule/utils": "workspace:*",
    "@mapomodule/core": "workspace:*"
  },
  "peerDependencies": {
    "@nuxt/ui": ">=4.0.0",
    "nuxt": ">=4.0.0"
  },
  "devDependencies": {
    "@nuxt/kit": "4.4.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "4.4.2",
    "tailwindcss": "^4.0.0",
    "@nuxt/ui": "^4.7.0",
    "nuxt": "^4.4.2",
    "vue": "^3.5.32",
    "vue-tsc": "^2.2.10"
  }
}
