{
  "name": "mapo-integrations-camomilla",
  "version": "0.0.0",
  "description": "Mapo integration for Camomilla CMS: Nitro proxy middleware with path rewriting and session sync",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/module.mjs"
    },
    "./types": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "nuxt-module-build build --stub --watch",
    "build": "nuxt-module-build build",
    "prepare": "nuxt-module-build build",
    "dev:prepare": "nuxt-module-build build --stub",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "nuxt": ">=4.0.0"
  },
  "devDependencies": {
    "@nuxt/kit": "4.4.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "4.4.2",
    "h3": "^1.15.3",
    "nitropack": "^2.13.3",
    "nuxt": "^4.4.2",
    "vue": "^3.5.32"
  }
}
