{
  "name": "@mapomodule/form",
  "version": "0.0.0",
  "description": "Mapo declarative typed form engine and field components",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/module.mjs"
    },
    "./types": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxt-module-build build --stub --watch",
    "prepare": "nuxt-module-build build --stub",
    "dev:prepare": "nuxt-module-build build --stub",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@internationalized/date": "^3.7.0",
    "@mapomodule/utils": "workspace:*",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@tiptap/vue-3": "^2.11.5",
    "leaflet": "^1.9.4",
    "vue-draggable-plus": "^0.6.0"
  },
  "optionalDependencies": {
    "@types/leaflet": "^1.9.18"
  },
  "peerDependencies": {
    "nuxt": ">=4.0.0",
    "vue": ">=3.5.0"
  },
  "devDependencies": {
    "@nuxt/kit": "4.4.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "4.4.2",
    "nuxt": "^4.4.2",
    "vitest": "^3.2.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-tsc": "^2.2.10",
    "zod": "^3.23.8"
  }
}
