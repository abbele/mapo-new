{
  "name": "mapo-monorepo",
  "private": true,
  "description": "Monorepo for @mapo/* packages and mapomodule",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "docs:dev": "pnpm --filter @mapo/docs dev",
    "docs:build": "turbo run docs:build",
    "dev:example": "pnpm --filter @mapo/example dev",
    "prepare": "husky",
    "release": "pnpm build && multi-semantic-release",
    "release:dry": "pnpm build && multi-semantic-release --dry-run",
    "publish:packages": "pnpm -r --filter './packages/**' publish --access public --no-git-checks"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.6",
  "lint-staged": {
    "**/*.{ts,tsx,vue,json,md}": [
      "prettier --write"
    ],
    "**/*.{ts,tsx,vue}": [
      "vitest related --run"
    ]
  },
  "multiSemanticRelease": {
    "deps": {
      "bump": "inherit",
      "release": "inherit"
    },
    "ignorePackages": [
      "@mapo/docs",
      "@mapo/example"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "multi-semantic-release": "^3.1.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
