{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {},
    "docs:build": {
      "dependsOn": ["types:generate"],
      "outputs": [".vitepress/dist/**"]
    },
    "types:generate": {
      "dependsOn": ["^build"],
      "outputs": ["dist/types/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
